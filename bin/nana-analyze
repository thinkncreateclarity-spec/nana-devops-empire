#!/usr/bin/env python3
import os
import csv
import json
import re
from collections import defaultdict
from datetime import datetime

BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
REPORTS_DIR = os.path.join(BASE_DIR, 'reports')
METRICS_FILE = os.path.join(REPORTS_DIR, 'history.csv')
ANALYSIS_FILE = os.path.join(REPORTS_DIR, 'analysis-latest.md')
RISK_JSON = os.path.join(REPORTS_DIR, 'risk-latest.json')

FIELDNAMES = [
    'run_id',
    'subsystem',
    'status',
    'criteria_met',
    'criteria_total',
    'commit_sha',
    'env',
    'phase',
    'anomaly_id',
]


def read_text(path):
    with open(path, encoding='utf-8', errors='replace') as f:
        return f.read()


def parse_report_file(path):
    fname = os.path.basename(path)
    if not (fname.startswith('test-') and fname.endswith('.md')):
        return None

    run_id = fname[len('test-'):-3]
    text = read_text(path)
    lines = [line.strip() for line in text.splitlines() if line.strip()]

    subsystem = None
    status = None
    criteria_met = None
    criteria_total = None

    for line in lines:
        m = re.match(r'^**Subsystem:**s*(.+?)s*$', line)
        if m:
            subsystem = m.group(1).strip()
            continue

        m = re.match(r'^**Status:**s*(.+?)s*$', line)
        if m:
            status_text = m.group(1).strip()
            if 'PASS' in status_text:
                status = 'PASS'
            elif 'FAIL' in status_text:
                status = 'FAIL'

            count_match = re.search(r'(d+)s*/s*(d+)s*criteria met', status_text, re.I)
            if count_match:
                criteria_met = int(count_match.group(1))
                criteria_total = int(count_match.group(2))
            else:
                count_match = re.search(r'(d+)s*/s*(d+)', status_text)
                if count_match:
                    criteria_met = int(count_match.group(1))
                    criteria_total = int(count_match.group(2))
            continue

        m = re.match(r'^Pass:s*(d+)s*/s*(d+)s*criteria mets*$', line, re.I)
        if m and criteria_met is None:
            criteria_met = int(m.group(1))
            criteria_total = int(m.group(2))

    if not subsystem or not status or criteria_met is None or criteria_total is None:
        return None

    return {
        'run_id': run_id,
        'subsystem': subsystem,
        'status': status,
        'criteria_met': criteria_met,
        'criteria_total': criteria_total,
    }


def parse_reports():
    rows = []
    if not os.path.isdir(REPORTS_DIR):
        return rows

    for fname in sorted(os.listdir(REPORTS_DIR)):
        if fname == 'current-run-id':
            continue
        path = os.path.join(REPORTS_DIR, fname)
        if not os.path.isfile(path):
            continue
        row = parse_report_file(path)
        if row:
            rows.append(row)

    return rows


def read_existing_run_ids():
    existing = set()
    if not os.path.exists(METRICS_FILE):
        return existing

    with open(METRICS_FILE, newline='', encoding='utf-8', errors='replace') as f:
        for r in csv.DictReader(f):
            rid = (r.get('run_id') or '').strip()
            if rid:
                existing.add(rid)
    return existing


def write_history(rows):
    existing = read_existing_run_ids()
    new_rows = [r for r in rows if r['run_id'] not in existing]

    os.makedirs(REPORTS_DIR, exist_ok=True)
    write_header = not os.path.exists(METRICS_FILE)

    with open(METRICS_FILE, 'a', newline='', encoding='utf-8') as f:
        writer = csv.DictWriter(f, fieldnames=FIELDNAMES)
        if write_header:
            writer.writeheader()

        for row in new_rows:
            anomaly_id = 'ANOM-FAIL' if row.get('status') == 'FAIL' else ''
            out = {
                'run_id': row.get('run_id', ''),
                'subsystem': row.get('subsystem', ''),
                'status': row.get('status', ''),
                'criteria_met': row.get('criteria_met', 0),
                'criteria_total': row.get('criteria_total', 0),
                'commit_sha': os.getenv('GIT_COMMIT', os.getenv('GITHUB_SHA', 'local-dev')),
                'env': os.getenv('NANA_ENV', 'local'),
                'phase': os.getenv('NANA_PHASE', 'phase-3'),
                'anomaly_id': anomaly_id,
            }
            writer.writerow(out)

    return len(new_rows)


def compute_risk(rows):
    stats = defaultdict(lambda: {'total': 0, 'fail': 0})
    for r in rows:
        stats[r['subsystem']]['total'] += 1
        if r['status'] == 'FAIL':
            stats[r['subsystem']]['fail'] += 1

    risk = {}
    for sub, s in stats.items():
        risk[sub] = round(s['fail'] / s['total'], 2) if s['total'] > 0 else 0.0
    return risk, stats


def risk_level(value):
    if value < 0.2:
        return 'LOW'
    if value < 0.5:
        return 'MEDIUM'
    return 'HIGH'


def write_analysis(rows, risk, stats):
    now = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    lines = [
        '# Nana-DevOps Sidecar Analytics',
        f'**Generated:** {now}',
        f'**Reports analyzed:** {len(rows)}',
        '',
        '## Per-Subsystem Risk Scores',
        '',
        '| Subsystem | Runs | Failures | Risk | Level |',
        '|-----------|------|----------|------|-------|',
    ]

    for sub in sorted(stats.keys()):
        s = stats[sub]
        r = risk.get(sub, 0.0)
        lines.append(
            f'| {sub} | {s["total"]} | {s["fail"]} | {r} | {risk_level(r)} |'
        )

    lines += ['', '## Recommendation', '']
    high = [sub for sub, value in risk.items() if value >= 0.5]
    medium = [sub for sub, value in risk.items() if 0.2 <= value < 0.5]

    if high:
        lines.append('- HIGH risk: ' + ', '.join(sorted(high)))
    if medium:
        lines.append('- MEDIUM risk: ' + ', '.join(sorted(medium)))
    if not high and not medium:
        lines.append('- All subsystems stable. No action required.')

    anomalies = [r for r in rows if r.get('anomaly_id')]
    lines += ['', '## Anomalies', '']
    if anomalies:
        for r in anomalies:
            lines.append(
                f'- {r.get("run_id", "")} | {r.get("subsystem", "")} | {r.get("anomaly_id", "")}'
            )
    else:
        lines.append('- No anomalies detected.')

    os.makedirs(REPORTS_DIR, exist_ok=True)
    with open(ANALYSIS_FILE, 'w', encoding='utf-8') as f:
        f.write('\n'.join(lines) + '\n')


def write_risk_json(risk, stats):
    os.makedirs(REPORTS_DIR, exist_ok=True)

    data = {
        'generated_at': datetime.utcnow().isoformat() + 'Z',
        'subsystems': {
            sub: {
                'runs': s.get('total', 0),
                'failures': s.get('fail', 0),
                'risk': float(risk.get(sub, 0.0)),
                'level': risk_level(risk.get(sub, 0.0)),
            }
            for sub, s in stats.items()
        },
    }

    with open(RISK_JSON, 'w', encoding='utf-8') as f:
        json.dump(data, f, indent=2)


def main():
    rows = parse_reports()
    added = write_history(rows)
    risk, stats = compute_risk(rows)
    write_analysis(rows, risk, stats)
    write_risk_json(risk, stats)

    print(f'Analyzed {len(rows)} reports ({added} new -> history.csv)')
    for sub in sorted(risk.keys()):
        r = risk[sub]
        s = stats[sub]
        level = risk_level(r)
        print(f'  {level}  {sub}: risk={r} ({s["fail"]}/{s["total"]} failures)')


if __name__ == '__main__':
    main()
