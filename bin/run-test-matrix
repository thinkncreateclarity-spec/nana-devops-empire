#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

SUBSYSTEMS="gitops revenue timer todo password mpc-watchdog"
RUN_ID="${RUN_ID:-$(date +%Y%m%d-%H%M%S)}"

echo "🧠 NANA-DEVOPS TEST MATRIX ($RUN_ID) 🧠"

for subsystem in $SUBSYSTEMS; do
  echo "→ Testing $subsystem (primary path)"
  ../bin/run-test "$subsystem" || echo "❌ $subsystem failed - redundancy path"
done

echo "MATRIX COMPLETE 📊 $(date)"
