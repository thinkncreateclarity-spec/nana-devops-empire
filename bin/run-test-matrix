#!/usr/bin/env bash
set -euo pipefail

echo "🧠 NANA-DEVOPS TEST MATRIX ($(date +%Y%m%d-%H%M%S)) 🧠"

if [ -d nana-devops ]; then
  echo "→ nana-devops directory present"
  ls nana-devops
else
  echo "→ nana-devops not present (expected)"
fi

SUBSYSTEMS=(
  "gitops|./gitops --version"
  "revenue|./revenue --help"
  "timer|./timer --help"
  "todo|./todo list || ./todo --help"
  "password|./password --help"
  "mpc-watchdog|./mpc-watchdog.sh --help || ./mpc-watchdog.sh status"
)

for entry in "${SUBSYSTEMS[@]}"; do
  SUBSYSTEM="${entry%%|*}"
  FALLBACK_CMD="${entry#*|}"

  echo "→ Testing $SUBSYSTEM (primary path)"
  if ./bin/run-test "$SUBSYSTEM"; then
    echo "✅ $SUBSYSTEM primary test PASSED"
  else
    echo "⚠️  $SUBSYSTEM primary test FAILED – running fallback smoke test"
    if bash -c "$FALLBACK_CMD"; then
      echo "🟡 $SUBSYSTEM fallback smoke test PASSED (DEGRADED)"
    else
      echo "🔴 $SUBSYSTEM fallback smoke test FAILED"
    fi
  fi
done

echo "MATRIX COMPLETE 📊 $(date)"
