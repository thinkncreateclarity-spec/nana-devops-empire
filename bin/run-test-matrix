#!/usr/bin/env bash
set -euo pipefail

echo "🧠 NANA-DEVOPS TEST MATRIX ($(date +%Y%m%d-%H%M%S)) 🧠"

for SUB in gitops revenue timer todo password mpc-watchdog; do
  echo "→ Testing $SUB (primary path)"
  if ! ./bin/run-test "$SUB"; then
    echo "❌ $SUB failed - redundancy path"
  fi
done

echo "MATRIX COMPLETE 📊 $(date)"
