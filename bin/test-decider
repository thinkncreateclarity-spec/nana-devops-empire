#!/usr/bin/env bash
set -euo pipefail

REPORTS_DIR="${REPORTS_DIR:-reports}"
MIN_REPORTS="${MIN_REPORTS:-5}"

PASSED="$(find "$REPORTS_DIR" -maxdepth 1 -name 'test-*.md' 2>/dev/null | wc -l || true)"

echo "🧠 NANA-DEVOPS HEALTH SCORE 🧠"
echo "Passed: $PASSED test reports in ./$REPORTS_DIR"

if [ "$PASSED" -ge "$MIN_REPORTS" ]; then
  echo "✅ GREEN = PRODUCTION READY"
  exit 0
else
  echo "🟡 YELLOW = NOT ENOUGH REPORTS (need >= $MIN_REPORTS)"
  exit 1
fi
