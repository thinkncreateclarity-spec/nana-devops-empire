#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

TOTAL_TESTS=6
GREEN_THRESHOLD=5
PASSED=$(find ../reports/ -name "test-*.md" 2>/dev/null | wc -l)
FAILED=$((TOTAL_TESTS - PASSED))

echo "🧠 NANA-DEVOPS HEALTH SCORE 🧠"
echo "Passed: $PASSED/$TOTAL_TESTS"

if [[ $PASSED -ge 5 ]]; then
  echo "✅ GREEN = PRODUCTION READY"
else
  echo "🟡 YELLOW = $(ls ../reports/ | wc -l) reports generated"
fi
