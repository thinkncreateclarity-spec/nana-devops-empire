#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

PASSED=$(find /data/data/com.termux/files/home/nana-devops/reports/ -name "test-*.md" 2>/dev/null | wc -l)

echo "🧠 NANA-DEVOPS HEALTH SCORE 🧠"
echo "Passed: $PASSED test reports in ~/nana-devops/reports/"
echo "Location: /data/data/com.termux/files/home/nana-devops/reports/"

if [[ $PASSED -ge 5 ]]; then
  echo "✅ GREEN = PRODUCTION READY"
else
  echo "🟡 YELLOW = $PASSED reports generated"
fi
